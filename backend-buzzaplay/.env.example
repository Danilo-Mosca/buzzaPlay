# File di esempio. Copiare come .env e inserire la password reale.
ADMIN_PASSWORD=your_password_here

# URL di connessione PostgreSQL (OPZIONALE — il server parte anche senza)
# Se mancante o non raggiungibile, il server parte comunque in modalità
# "graceful": le domande Quiz non sono disponibili, ma tutto il resto funziona.
# Render fornisce automaticamente questa variabile nel deploy.
# Formato: postgres://user:password@host:5432/dbname
# DATABASE_URL=postgres://user:password@host:5432/dbname
